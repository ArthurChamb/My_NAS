--DHCP-- https://www.security-helpzone.com/2013/06/16/isc-dhcp-server-configurer-un-serveur-dhcp/

/etc/dhcp/dhcpd.conf ->
ddns-update-style none;
option domain-name "rushlab.lan";
option domain-name-servers 192.168.42.2;
default-lease-time 86400;
max-lease-time 604800;
authoritative;
log-facility local7;
subnet 192.168.42.0 netmask 255.255.255.192 {
 	range 192.168.42.4 192.168.42.60;
 	option routers 192.168.42.1;
	option subnet-mask 255.255.255.192;
	option broadcast-address 192.168.42.192;
}

/etc/default/isc-dhcp-server -> Set Interface to eth0

test -> dhclient eth0

