--DNS-- http://mixeduperic.com/ubuntu/seven-easy-steps-to-setting-up-an-interal-dns-server-on-ubuntu.html

COMMANDE MIRACLE SI PROBLEME -> named-checkconf (check si la conf a pas un problème de syntaxe)

/etc/bind/named.conf.options -> 8.8.8.8/8.8.4.4 pour remplacer les forwarders

/etc/bind/named.conf.local ->
zone "rushlab.lan" {
	type master;
	file "/etc/bind/db.rushlab.lan";
	};

zone "42.168.192.in-addr.arpa" {
	type master;
	notify no;
	file "/etc/bind/db.192";
};

cp /etc/bind/db.local /etc/bind/db.rushlab.lan
/etc/bind/db.rushlab.lan ->
@	IN	SOA	rush-dhcp-dns.rushlab.lan. rush.localhost. (
			      2		; Serial
			 604800		; Refresh
			  86400		; Retry
			2419200		; Expire
			 604800 )	; Negative Cache TTL
;
@	IN	NS	rush-dhcp-dns.rushlab.lan.
@	IN	A	127.0.0.1
@	IN	AAAA	::1

rush-gateway	IN	A	192.168.42.1
rush-dhcp-dns	IN	A	192.168.42.2
rush-web-wiki	IN	A	192.168.42.3

wiki		IN	CNAME	rush-web-wiki.rushlab.lan.
intra		IN	CNAME	rush-web-wiki.rushlab.lan.

sudo cp /etc/bind/db.127 /etc/bind/db.192
/etc/bind/db.192 -> 
@	IN	SOA	rush-dhcp-dns.rushlab.lan. rush.localhost. (
			      1		; Serial
			 604800		; Refresh
			  86400		; Retry
			2419200		; Expire
			 604800 )	; Negative Cache TTL
;
@	IN	NS	rush-dhcp-dns.rushlab.lan.
1	IN	PTR	rush-gateway.rushlab.lan.
2	IN	PTR	rush-dhcp-dns.rushlab.lan.
3	IN	PTR	rush-web-wiki.rushlab.lan.

